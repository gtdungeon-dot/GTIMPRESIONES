{
  "name": "gt-impresiones-cotizador",
  "version": "2.0.0",
  "description": "GT Impresiones Cotizador - Calculadora de Impresión 3D",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.gtimpresiones.cotizador",
    "productName": "GT Impresiones Cotizador",
    "win": {
      "target": "nsis",
      "icon": "src/assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1"
  }
}
